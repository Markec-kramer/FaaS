rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Uporabniški profili
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Naprave - samo lastnik
    match /devices/{deviceId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Senzorski podatki - samo lastnik
    match /sensorData/{dataId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if true; // IoT naprave pišejo brez avtentikacije
    }

    // Pravila avtomatizacije - samo lastnik
    match /automationRules/{ruleId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Opozorila - samo lastnik
    match /alerts/{alertId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Poročila - samo lastnik
    match /reports/{reportId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Slike kamer - samo lastnik
    match /cameraImages/{imageId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Obvestila - samo lastnik
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Logi - samo branje za lastnika
    match /logs/{logId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }
  }
}
